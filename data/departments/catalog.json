      "name_en": "Respiratory Medicine",
      "sort_order": 10,
      "description": "胸片与肺部病灶分析；COPD/肺炎/气胸等呼吸专科用药审查",
      "imaging_sources": ["mimic_cxr"],
      "default_models": ["cxr_lesion", "sam2d"],
