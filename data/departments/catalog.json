          "notes": "多标签胸片标注，可补充 cxr_lesion 训练/验证"
        }
      ],
      "vision_models": [
        {
          "model_id": "cxr_lesion",
          "name": "CXR Lesion (U-Net + pathology)",
          "task": "胸片病灶像素分割 — opacity/pneumonia 用 RSNA U-Net；effusion 等用 pathology 定位",
          "download": "python scripts/download_models.py --cxr-lesion"
        },
        {
          "model_id": "sam2d",
          "name": "SAM2D",
          "task": "交互式 2D 病灶框选",
          "download": "python scripts/download_models.py --sam2d"
        }
      ],
      "nav_routes": ["/imaging", "/consult", "/chat", "/rule-review", "/drugs", "/cases", "/agents", "/settings"]
    },
