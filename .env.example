# =============================================================================
# MedSafe Environment Variables
# =============================================================================
# Copy: cp .env.example .env
# 本项目禁止使用 mock / 假数据。未配置 API Key 时，LLM 相关接口返回 503。

# ── LLM API（Extract / 多智能体会诊）────────────────────────────────────
MEDSAFE_LLM__PROVIDER=deepseek
MEDSAFE_LLM__API_KEY=
MEDSAFE_LLM__BASE_URL=https://api.deepseek.com/v1
MEDSAFE_LLM__MODEL=deepseek-chat

# ── Multi-Agent ─────────────────────────────────────────────────────────
MEDSAFE_AGENTS__RULE_STRICT=true

# ── Server ──────────────────────────────────────────────────────────────
MEDSAFE_SERVER__HOST=0.0.0.0
MEDSAFE_SERVER__PORT=8000

# ── Logging ─────────────────────────────────────────────────────────────
MEDSAFE_LOGGING__LEVEL=INFO
MEDSAFE_LOGGING__FORMAT=console

# ── Vision LLM (Qwen3-VL @ 百炼 Model Studio) ───────────────────────────
# 控制台：https://bailian.console.aliyun.com/cn-beijing
# 文档：https://help.aliyun.com/zh/model-studio/qwen-vl-compatible-with-openai
MEDSAFE_VISION_LLM__PROVIDER=qwen
MEDSAFE_VISION_LLM__API_KEY=
MEDSAFE_VISION_LLM__REGION=cn-beijing
MEDSAFE_VISION_LLM__WORKSPACE_ID=
# 留空则按 workspace_id + region 自动拼接 maas 域名；也可写完整 URL
MEDSAFE_VISION_LLM__BASE_URL=
MEDSAFE_VISION_LLM__MODEL=qwen3-vl-plus

# ── DeepSeek multi-agent report synthesis ───────────────────────────────
MEDSAFE_DEEPSEEK__API_KEY=
MEDSAFE_DEEPSEEK__BASE_URL=https://api.deepseek.com/v1
MEDSAFE_DEEPSEEK__MODEL=deepseek-chat

# ── Chat (ReAct + Graph RAG) ────────────────────────────────────────────
MEDSAFE_CHAT__PROVIDER=deepseek
MEDSAFE_CHAT__API_KEY=
MEDSAFE_CHAT__BASE_URL=https://api.deepseek.com/v1
MEDSAFE_CHAT__MODEL=deepseek-chat

# ── Embedding (MCP 文档 RAG + 药典语义搜索，可与 Chat 分离) ─────────────
# LM Studio：加载 embedding 模型后启动 Local Server (默认 http://localhost:1234)
# model 可填短名 nomic-embed-text，系统会自动匹配 LM Studio 返回的完整 id
MEDSAFE_EMBEDDING__PROVIDER=lmstudio
MEDSAFE_EMBEDDING__API_KEY=lm-studio
MEDSAFE_EMBEDDING__BASE_URL=http://localhost:1234/v1
MEDSAFE_EMBEDDING__MODEL=nomic-embed-text
# 本地 transformers 模式：MEDSAFE_EMBEDDING__PROVIDER=local
# MEDSAFE_EMBEDDING__MODEL_DIR=models/drug_search

# ── Multi-Agent debate ──────────────────────────────────────────────────
MEDSAFE_DEBATE__ENABLED=true
MEDSAFE_DEBATE__MAX_ROUNDS=3
MEDSAFE_DEBATE__CONFIDENCE_THRESHOLD=0.75
MEDSAFE_DEBATE__FLAG_FOR_HUMAN_ON_NO_CONSENSUS=true

# ── Docker Ports ────────────────────────────────────────────────────────
MEDSAFE_API_PORT=8000
MEDSAFE_WEB_PORT=3000

# ── Remote imaging segment worker (AutoDL / cloud GPU) ─────────────────
# 本地 API 启用后优先走云端；不可达且 fallback_to_local=true 时降级本地 CPU/GPU
# AutoDL 上运行：bash scripts/start_segment_worker.sh
# 本机隧道：ssh -p <port> -L 9000:127.0.0.1:9000 root@connect.xxx.seetacloud.com
# MEDSAFE_IMAGING__REMOTE__ENABLED=true
# MEDSAFE_IMAGING__REMOTE__BASE_URL=http://127.0.0.1:9000
# MEDSAFE_IMAGING__REMOTE__API_TOKEN=change-me
# MEDSAFE_IMAGING__REMOTE__FALLBACK_TO_LOCAL=true
# MEDSAFE_IMAGING__REMOTE__LOCAL_FALLBACK_DEVICE=cpu
# MEDSAFE_IMAGING__DEVICE=cuda
