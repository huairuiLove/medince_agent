# =============================================================================
# MedSafe Environment Variables
# =============================================================================
# Copy: cp .env.example .env

# ── LLM API ─────────────────────────────────────────────────────────────
# Provider: mock (offline demo) | openai | deepseek | qwen
MEDSAFE_LLM__PROVIDER=mock
MEDSAFE_LLM__API_KEY=
MEDSAFE_LLM__BASE_URL=https://api.openai.com/v1
MEDSAFE_LLM__MODEL=gpt-4o-mini

# DeepSeek example:
# MEDSAFE_LLM__PROVIDER=openai
# MEDSAFE_LLM__API_KEY=sk-...
# MEDSAFE_LLM__BASE_URL=https://api.deepseek.com/v1
# MEDSAFE_LLM__MODEL=deepseek-chat

# ── Multi-Agent ─────────────────────────────────────────────────────────
MEDSAFE_AGENTS__RULE_STRICT=true

# ── Server ──────────────────────────────────────────────────────────────
MEDSAFE_SERVER__HOST=0.0.0.0
MEDSAFE_SERVER__PORT=8000

# ── Logging ─────────────────────────────────────────────────────────────
MEDSAFE_LOGGING__LEVEL=INFO
MEDSAFE_LOGGING__FORMAT=console

# ── Vision LLM (Qwen3-VL) ───────────────────────────────────────────────
MEDSAFE_VISION_LLM__PROVIDER=mock
MEDSAFE_VISION_LLM__API_KEY=
MEDSAFE_VISION_LLM__BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEDSAFE_VISION_LLM__MODEL=qwen-vl-max-latest

# ── DeepSeek multi-agent report synthesis ───────────────────────────────
MEDSAFE_DEEPSEEK__API_KEY=
MEDSAFE_DEEPSEEK__BASE_URL=https://api.deepseek.com/v1
MEDSAFE_DEEPSEEK__MODEL=deepseek-chat

# ── Docker Ports ────────────────────────────────────────────────────────
MEDSAFE_API_PORT=8000
MEDSAFE_WEB_PORT=3000
